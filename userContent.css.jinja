/* Hide non-chat Workplace icons on chat pages */
@-moz-document url-prefix("https://fb.workplace.com/chat") {
  div[aria-label="Workplace and intern apps"] [role="row"]:not(:nth-child(3)) {
    display: none !important;
  }
}

/* Hide Workplace chat icon on non-chat pages */
@-moz-document url-prefix("https://fb.workplace.com/groups"), url("https://fb.workplace.com/") {
  div[aria-label="Workplace and intern apps"] [role="row"]:nth-child(3) {
    display: none !important;
  }
}