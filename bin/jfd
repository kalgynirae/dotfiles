#!/usr/bin/env bash

if ! repo_root=$(jj root); then
  echo >&2 "Failed to get repository root. Is this a jj repo?"
  exit 1
fi

read -rd '' JIFFYDIFFY <<JIFFYDIFFY
_______________________________________________________________________
______  /__(_)__  __/__  __/____  ____  __ \__(_)__  __/__  __/____  __
___ _  /__  /__  /_ __  /_ __  / / /_  / / /_  /__  /_ __  /_ __  / / /
/ /_/ / _  / _  __/ _  __/ _  /_/ /_  /_/ /_  / _  __/ _  __/ _  /_/ /_
\____/  /_/  /_/    /_/    _\__, / /_____/ /_/  /_/    /_/    _\__, /__
__________________________ /____/____________________________ /____/___

         ~~~~~~~~ We'll have your diff up in a jiffy! ~~~~~~~~
JIFFYDIFFY
echo >&2 "$JIFFYDIFFY"

add-bookmark() {
  local change=$1
  local message=$(jj log -r "$change" --no-graph -T 'description.first_line()' | sed 's/\[[^]]*\]//g')
  if ! name=$(ask-llm -q "Respond with a short (hyphen-separated, fewer than 12 characters) branch name based on this commit message: $message"); then
    echo >&2 "ask-llm failed"
    return 1
  fi
  local bookmark=$bookmark_prefix/$name
  if ! jj bookmark create -r "$change" "$bookmark"; then
    echo >&2 "Failed to create bookmark $bookmark at change $change"
    return 1
  fi
  echo "$bookmark"
}

auto_track_pattern=$(jj config get remotes.origin.auto-track-bookmarks)
if [[ $auto_track_pattern != *"/*" ]]; then
  echo >&2 "$0: Unsupported auto-track-bookmarks setting: $auto_track_pattern"
  exit 1
fi
bookmark_prefix=${auto_track_pattern%/\*}

if ! changes=($(jj log -r stack --no-graph --reversed -T 'change_id ++ "\n"')); then
  echo >&2 "$0: Failed to list the current stack"
  exit 1
fi

bookmarks=()
for change in "${changes[@]}"; do
  if ! change_bookmarks=($(jj log -r "$change" --no-graph -T 'local_bookmarks.map(|b| b.name())')); then
    echo >&2 "$0: Failed to list bookmarks for change $change"
    exit 1
  fi
  bookmark=
  for cb in ${change_bookmarks[@]}; do
    if [[ $cb == $auto_track_pattern ]]; then
      bookmark=$cb
      break
    fi
  done
  if [[ ! $bookmark ]]; then
    if ! bookmark=$(add-bookmark "$change"); then
      echo >&2 "$0: Failed to add a bookmark to change $change"
      exit 1
    fi
  fi
  bookmarks+=("$bookmark")
done

for (( i = ${#bookmarks[@]} - 1; i >= 0; i-- )); do
  if ! gt untrack "${bookmarks[i]}" --force; then
    echo >&2 "$0: 'gt untrack' failed; aborting"
    exit 1
  fi
done

# TODO: Figure out the correct base for the stack instead of assuming main.
# It might be someone else's PR. Might make sense to find the first non-tracked
# remote bookmark?
previous=main
for b in "${bookmarks[@]}"; do
  if ! gt track "$b" --parent "$previous"; then
    echo >&2 "$0: 'gt track' failed; aborting"
    exit 1
  fi
  previous=$b
done

if ! gt submit --draft --no-edit --branch "${bookmarks[-1]}" --force; then
  echo >&2 "$0: 'gt submit' failed"
  exit 1
fi
