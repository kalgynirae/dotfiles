#!/bin/bash
# usage: <SCRIPT> [ARGS...]
#
# Arguments:
#   [ARGS...]    args to pass to 'jj log' (default: -r stack_context)

usage() {
  awk <"$0" -v script="$0" '/$^/{exit}; NR==2,0{gsub(/<SCRIPT>/, script); print substr($0, 3)}'
}

if [[ " $* " == " --help " ]]; then
  usage
  exit
fi

if ! jj_root=$(jj workspace root); then
  echo >&2 "$0: 'jj workspace root' failed (is this a jj repo?)"
  exit 1
fi
jj_repo_path=$jj_root/.jj/repo
if [[ -f $jj_repo_path ]]; then
  jj_repo_path=$(dirname "$jj_repo_path")/$(<"$jj_repo_path")
fi

if (( $# == 0 )); then
  logargs=(-r stack_context)
else
  logargs=("$@")
fi

watchexec --ignore-nothing --watch "$jj_repo_path"/op_heads/heads --clear -o queue --shell none -- jj --ignore-working-copy --no-pager log "${logargs[@]}"
