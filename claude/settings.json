{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_ENABLE_AUTO_MODE": "1"
  },
  "permissions": {
    "allow": [
      "Bash(gh *)""
    ],
    "deny": [
      "Bash(gt *)"
    ],
    "defaultMode": "auto"
  },
  "skillOverrides": {
    "address-reviewer-feedback": "off",
    "link-stack-to-linear": "off",
    "monitor-pr": "off",
    "new-pr": "off",
    "new-worktree": "off",
    "repair-ci-failures": "off",
    "resolve-merge-conflicts": "off"
  },
  "awaySummaryEnabled": false,
  "theme": "dark-ansi",
  "preferredNotifChannel": "terminal_bell",
  "skipAutoPermissionPrompt": true,
  "defaultMode": "acceptEdits"
}
